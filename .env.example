# Bookwyrm Docker Environment Configuration
# Copy this file to .env and customize the values

# ============================================================================
# REQUIRED SETTINGS - Must be configured before deployment
# ============================================================================

# Domain Configuration
# The domain where Bookwyrm will be accessible (e.g., bookwyrm.example.com or localhost)
BOOKWYRM_DOMAIN=bookwyrm.local

# Secret Key (CRITICAL: Generate a unique random string)
# Generate with: openssl rand -base64 45
BOOKWYRM_SECRET_KEY=your_very_long_secret_key_here_at_least_50_characters_CHANGE_ME

# Database Password
# Generate with: openssl rand -base64 32
BOOKWYRM_DB_PASSWORD=your_secure_database_password_CHANGE_ME

# Redis Passwords
# Generate with: openssl rand -base64 32
BOOKWYRM_REDIS_ACTIVITY_PASSWORD=your_secure_redis_activity_password_CHANGE_ME
BOOKWYRM_REDIS_BROKER_PASSWORD=your_secure_redis_broker_password_CHANGE_ME

# ============================================================================
# NETWORK SETTINGS
# ============================================================================

# Port where Bookwyrm will be accessible
# Default: 8000 (access at http://localhost:8000)
BOOKWYRM_PORT=8000

# HTTPS Configuration
# Set to true if using HTTPS (requires reverse proxy with SSL certificates)
BOOKWYRM_USE_HTTPS=false

# CSRF Trusted Origins
# Comma-separated list of allowed origins for CSRF protection
# Example: http://localhost:8000,http://192.168.1.100:8000,https://bookwyrm.example.com
BOOKWYRM_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ============================================================================
# DATABASE SETTINGS (Optional - uses defaults if not set)
# ============================================================================

# Database Configuration
BOOKWYRM_DB_USER=bookwyrm
BOOKWYRM_DB_NAME=bookwyrm

# ============================================================================
# EMAIL SETTINGS (Optional - emails won't be sent if not configured)
# ============================================================================

# Email Server Configuration
# Leave empty to disable email functionality (app will work but won't send emails)
# For Gmail: smtp.gmail.com with an app-specific password
# For SendGrid: smtp.sendgrid.net with API key as password
BOOKWYRM_EMAIL_HOST=
BOOKWYRM_EMAIL_PORT=587
BOOKWYRM_EMAIL_USER=
BOOKWYRM_EMAIL_PASSWORD=

# Email Security
# Use TLS (recommended for port 587)
BOOKWYRM_EMAIL_USE_TLS=true
# Use SSL (use for port 465, mutually exclusive with TLS)
BOOKWYRM_EMAIL_USE_SSL=false

# Email Sender Information
BOOKWYRM_EMAIL_SENDER_NAME=BookWyrm
# If not set, uses BOOKWYRM_DOMAIN
BOOKWYRM_EMAIL_SENDER_DOMAIN=

# ============================================================================
# TIMEZONE
# ============================================================================

# Server timezone (used for logs and scheduled tasks)
# Examples: UTC, America/New_York, Europe/London, Asia/Tokyo
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC

# ============================================================================
# NOTES
# ============================================================================

# Minimum Required Variables:
# - BOOKWYRM_DOMAIN
# - BOOKWYRM_SECRET_KEY
# - BOOKWYRM_DB_PASSWORD
# - BOOKWYRM_REDIS_ACTIVITY_PASSWORD
# - BOOKWYRM_REDIS_BROKER_PASSWORD

# Security Best Practices:
# 1. Never commit .env file to version control
# 2. Use strong, unique passwords (32+ characters)
# 3. Rotate SECRET_KEY periodically
# 4. Use HTTPS in production (BOOKWYRM_USE_HTTPS=true)
# 5. Backup database regularly (data/pgdata directory)

# Quick Start Commands:
# 1. cp .env.example .env
# 2. Edit .env with your values
# 3. make setup
# 4. Access at http://localhost:8000

# For production deployments:
# - Set up a reverse proxy (nginx, Caddy, Traefik) for HTTPS
# - Configure proper domain and DNS
# - Enable email for password resets and notifications
# - Set up regular database backups
# - Monitor logs for errors
